<group name="local,custom,ubuntu_soc,">
  <rule id="100500" level="8">
    <decoded_as>json</decoded_as>
    <field name="location" type="pcre2">/var/log/suricata/eve\.json</field>
    <field name="event_type">alert</field>
    <field name="alert.signature" type="pcre2">(?i)(nmap|masscan|scan)</field>
    <description>Suricata network scan detected from $(src_ip) to $(dest_ip): $(alert.signature)</description>
    <group>suricata,reconnaissance,network_scan,</group>
    <mitre>
      <id>T1046</id>
    </mitre>
  </rule>

  <rule id="100501" level="10">
    <decoded_as>json</decoded_as>
    <field name="location" type="pcre2">/var/log/suricata/eve\.json</field>
    <field name="event_type">alert</field>
    <field name="alert.category" type="pcre2">(?i)(attempted|exploit|trojan|malware|suspicious)</field>
    <description>Suricata suspicious traffic detected from $(src_ip) to $(dest_ip): $(alert.signature)</description>
    <group>suricata,network_anomaly,suspicious_traffic,</group>
  </rule>

  <rule id="100510" level="5">
    <decoded_as>json</decoded_as>
    <field name="location" type="pcre2">/opt/cowrie/var/log/cowrie/cowrie\.json</field>
    <field name="eventid">cowrie.login.failed</field>
    <description>Cowrie login failure from $(src_ip) using username $(username)</description>
    <group>cowrie,authentication_failed,honeypot,ssh,</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <rule id="100511" level="10" frequency="5" timeframe="120">
    <if_matched_sid>100510</if_matched_sid>
    <same_field>src_ip</same_field>
    <description>Cowrie SSH brute force detected from $(src_ip)</description>
    <group>cowrie,authentication_failed,ssh_bruteforce,honeypot,</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <rule id="100520" level="12">
    <decoded_as>json</decoded_as>
    <field name="src_ip" type="pcre2">\d+\.\d+\.\d+\.\d+</field>
    <list field="src_ip" lookup="address_match_key">etc/lists/opencti-indicators-ip</list>
    <description>Threat intelligence match for source IP $(src_ip)</description>
    <group>threat_intel,opencti,ioc,srcip,</group>
  </rule>

  <rule id="100521" level="12">
    <decoded_as>json</decoded_as>
    <field name="dest_ip" type="pcre2">\d+\.\d+\.\d+\.\d+</field>
    <list field="dest_ip" lookup="address_match_key">etc/lists/opencti-indicators-ip</list>
    <description>Threat intelligence match for destination IP $(dest_ip)</description>
    <group>threat_intel,opencti,ioc,dstip,</group>
  </rule>

  <rule id="100522" level="11">
    <decoded_as>json</decoded_as>
    <field name="http.hostname" type="pcre2">.+</field>
    <list field="http.hostname" lookup="match_key">etc/lists/opencti-indicators-domain</list>
    <description>Threat intelligence domain match for $(http.hostname)</description>
    <group>threat_intel,opencti,ioc,domain,</group>
  </rule>

  <rule id="100523" level="11">
    <decoded_as>json</decoded_as>
    <field name="tls.sni" type="pcre2">.+</field>
    <list field="tls.sni" lookup="match_key">etc/lists/opencti-indicators-domain</list>
    <description>Threat intelligence TLS SNI match for $(tls.sni)</description>
    <group>threat_intel,opencti,ioc,domain,</group>
  </rule>

  <rule id="100524" level="11">
    <decoded_as>json</decoded_as>
    <field name="sha256" type="pcre2">[A-Fa-f0-9]{64}</field>
    <list field="sha256" lookup="match_key">etc/lists/opencti-indicators-sha256</list>
    <description>Threat intelligence SHA256 match for $(sha256)</description>
    <group>threat_intel,opencti,ioc,hash,</group>
  </rule>
</group>
