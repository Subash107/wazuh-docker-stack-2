# Runtime values for the canonical Ubuntu sensor blueprint.
# Copy these values into your deployment invocation or automation wrapper.

INSTALL_PROFILE=full
MANAGER_IP=192.168.1.3
MANAGER_PORT=1514
SENSOR_IP=192.168.1.6
LAN_CIDR=192.168.1.0/24
TZ=UTC

# Required for INSTALL_PROFILE=full
PIHOLE_WEBPASSWORD=change-this-before-deploy
MITMPROXY_WEBPASSWORD=change-this-before-deploy

PIHOLE_UPSTREAM_DNS=192.168.1.1
PIHOLE_LISTENING_MODE=all
PIHOLE_WEB_PORT=8080
MITMPROXY_PROXY_PORT=8082
MITMPROXY_WEB_PORT=8083
PIHOLE_IMAGE=pihole/pihole@sha256:ee348529cea9601df86ad94d62a39cad26117e1eac9e82d8876aa0ec7fe1ba27
MITMPROXY_IMAGE=mitmproxy/mitmproxy@sha256:743b6cdc817211d64bc269f5defacca8d14e76e647fc474e5c7244dbcb645141
COMPOSE_PROJECT_ROOT=/opt/monitoring-sensor
