{
    auto_https disable_redirects
    admin off
}

(gateway_auth) {
    basic_auth {
        {$GATEWAY_ADMIN_USERNAME} {$GATEWAY_ADMIN_PASSWORD_HASH}
    }
}

https://{$MONITORING_GATEWAY_HOST}:9443, https://127.0.0.1:9443, https://localhost:9443 {
    tls internal

    route {
        handle /healthz {
            reverse_proxy monitoring-service-index:9088
        }

        import gateway_auth
        reverse_proxy monitoring-service-index:9088
    }
}

https://{$MONITORING_GATEWAY_HOST}:9444, https://127.0.0.1:9444, https://localhost:9444 {
    tls internal

    route {
        handle /healthz {
            rewrite * /-/healthy
            reverse_proxy prometheus:9090
        }

        import gateway_auth
        reverse_proxy prometheus:9090
    }
}

https://{$MONITORING_GATEWAY_HOST}:9445, https://127.0.0.1:9445, https://localhost:9445 {
    tls internal

    route {
        handle /healthz {
            rewrite * /-/healthy
            reverse_proxy alertmanager:9093
        }

        import gateway_auth
        reverse_proxy alertmanager:9093
    }
}

https://{$MONITORING_GATEWAY_HOST}:9446, https://127.0.0.1:9446, https://localhost:9446 {
    tls internal

    route {
        handle /healthz {
            rewrite * /metrics
            reverse_proxy blackbox-exporter:9115
        }

        import gateway_auth
        reverse_proxy blackbox-exporter:9115
    }
}

https://{$MONITORING_GATEWAY_HOST}:9447, https://127.0.0.1:9447, https://localhost:9447 {
    tls internal

    route {
        handle /healthz {
            reverse_proxy host.docker.internal:5601
        }

        import gateway_auth
        reverse_proxy host.docker.internal:5601
    }
}
