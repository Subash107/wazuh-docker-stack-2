# Copy this file to offsite-backup.env and fill in your real target details.
# This config file is intentionally outside the regular bundle backups so your off-host
# credentials are not included in the exported recovery snapshots.

JOB_NAME=Monitoring Offsite Backup

# Supported values:
#   filesystem -> UNC path, NAS share, mounted drive
#   rclone     -> any rclone remote such as S3, B2, Wasabi, Google Drive, SFTP
TARGET_TYPE=filesystem

# Example filesystem target:
# TARGET_ROOT=\\backup-server\monitoring-recovery
#
# Example rclone target:
# TARGET_ROOT=wasabi:monitoring-recovery/subash
TARGET_ROOT=

# Retention defaults.
LOCAL_KEEP_COUNT=7
REMOTE_KEEP_COUNT=30
LOG_KEEP_COUNT=30

# Existing monitoring host and Ubuntu sensor VM connection details.
HOST_ROOT=D:\Monitoring
VM_ADDRESS=192.168.1.6
VM_SSH_USER=subash

# Use either *_FILE or the inline value for each secret.
# VM_SSH_PASSWORD_FILE=D:\Monitoring\wazuh-docker-stack\single-node\recovery-bundle\config\secrets\vm_ssh_password.txt
# VM_SUDO_PASSWORD_FILE=D:\Monitoring\wazuh-docker-stack\single-node\recovery-bundle\config\secrets\vm_sudo_password.txt
VM_SSH_PASSWORD=
VM_SUDO_PASSWORD=

# Optional path to a dedicated rclone config file when TARGET_TYPE=rclone.
# If omitted, the runner will use the system rclone if available, otherwise it will
# download a portable copy into recovery-bundle\tools\rclone on first use.
# RCLONE_CONFIG_PATH=D:\Monitoring\wazuh-docker-stack\single-node\recovery-bundle\config\rclone.conf
RCLONE_CONFIG_PATH=
RCLONE_DOWNLOAD_URL=https://downloads.rclone.org/rclone-current-windows-amd64.zip
