# Hyper-V one-click Ubuntu sensor VM provisioning.
# Copy to hyperv-provision.env and adjust only if you need different sizing,
# naming, or network behavior.

VM_NAME=monitoring-sensor
VM_HOSTNAME=ubuntu-sensor
VM_DATA_ROOT=D:\Monitoring\wazuh-docker-stack\single-node\recovery-bundle\hyperv
VM_CPU_COUNT=2
VM_MEMORY_STARTUP_MB=4096
VM_GENERATION=2
DHCP_WAIT_SECONDS=900

# Leave blank to auto-detect the existing external vSwitch.
VM_SWITCH_NAME=

# If no external switch exists, auto-create one on the active LAN adapter.
AUTO_CREATE_EXTERNAL_SWITCH=true

# Leave blank to auto-select the adapter that owns the default IPv4 route.
SWITCH_ADAPTER_NAME=

# Leave MANAGER_IP blank to auto-detect the host IPv4 on the selected adapter.
MANAGER_IP=

# Official Ubuntu cloud image published for Azure/Hyper-V. Update if you want a
# different release stream.
UBUNTU_IMAGE_URL=https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64-azure.vhd.tar.gz
IMAGE_CACHE_ROOT=D:\Monitoring\wazuh-docker-stack\single-node\recovery-bundle\cache\ubuntu

VM_ADMIN_USER=subash
VM_ADMIN_PASSWORD_FILE=D:\Monitoring\wazuh-docker-stack\single-node\recovery-bundle\config\secrets\hyperv_vm_admin_password.txt
