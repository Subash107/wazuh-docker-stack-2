# Local environment and secrets
.env
wazuh-docker-stack/.env
wazuh-docker-stack/multi-node/config/wazuh_dashboard/wazuh.yml
wazuh-docker-stack/single-node/config/wazuh_dashboard/wazuh.yml
wazuh-docker-stack/build-docker-images/wazuh-indexer/config/internal_users.yml
wazuh-docker-stack/multi-node/config/wazuh_indexer/internal_users.yml
wazuh-docker-stack/single-node/config/wazuh_indexer/internal_users.yml
secrets/*
!secrets/README.md
wazuh-docker-stack/single-node/config/wazuh_indexer_ssl_certs/**
!wazuh-docker-stack/single-node/config/wazuh_indexer_ssl_certs/README.md
!wazuh-docker-stack/build-docker-images/wazuh-indexer/config/internal_users.yml.example
!wazuh-docker-stack/multi-node/config/wazuh_dashboard/wazuh.yml.example
!wazuh-docker-stack/multi-node/config/wazuh_indexer/internal_users.yml.example
!wazuh-docker-stack/single-node/config/wazuh_dashboard/wazuh.yml.example
!wazuh-docker-stack/single-node/config/wazuh_indexer/internal_users.yml.example
wazuh-docker-stack/single-node/recovery-bundle/config/secrets/*
!wazuh-docker-stack/single-node/recovery-bundle/config/secrets/README.md
wazuh-docker-stack/single-node/recovery-bundle/config/*.env
!wazuh-docker-stack/single-node/recovery-bundle/config/*.env.example

# Logs, local rollout evidence, and caches
logs/host/*
!logs/host/.gitkeep
logs/deployments/*
!logs/deployments/.gitkeep
*.log
__pycache__/
*.pyc

# Archives, backups, and generated recovery artifacts
archives/
projects/reference/
wazuh-docker-stack/single-node/recovery-bundle/backups/
wazuh-docker-stack/single-node/recovery-bundle/offline-archive/
wazuh-docker-stack/single-node/recovery-bundle/blueprints/
wazuh-docker-stack/single-node/recovery-bundle/logs/
wazuh-docker-stack/single-node/.bundle_stamp
*.zip
*.tgz

# Local binaries and media exports
Sysmon/
media/assets/
soc-stack/

# Editor and assistant local state
.claude/
